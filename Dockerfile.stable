# Dockerfile.stable — Stable Rule-Based Fallback API
# Builds the GREEN slot image: zuriyat/sentiment-api:stable
FROM python:3.10-slim

WORKDIR /app

RUN apt-get update && apt-get install -y gcc && rm -rf /var/lib/apt/lists/*

# Stable app only needs flask and requests — no torch/transformers
COPY stable-fallback/app.py app.py

RUN pip install --no-cache-dir flask==3.0.3 requests==2.32.3

RUN mkdir -p /app/logs

EXPOSE 5000

CMD ["python", "app.py"]
